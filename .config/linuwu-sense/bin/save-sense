#!/bin/sh
# save-sense — snapshot current Linuwu-Sense state to disk.
# Run as root by the runit shutdown.d hook (and can be run manually any time).

set -eu

BASE="/sys/module/linuwu_sense/drivers/platform:acer-wmi/acer-wmi"
PREDATOR="$BASE/predator_sense"
KB="$BASE/four_zoned_kb"
STATE_DIR="/var/lib/linuwu-sense"
STATE_FILE="$STATE_DIR/state"
PROFILE_PATH="/sys/firmware/acpi/platform_profile"

[ -d "$PREDATOR" ] || exit 0

mkdir -p "$STATE_DIR"
tmp="$STATE_FILE.tmp"

read_field() {
	[ -e "$1" ] && cat "$1" 2>/dev/null || true
}

{
	printf '# Auto-generated by save-sense on %s\n' "$(date -Iseconds 2>/dev/null || date)"

	if [ -e "$KB/per_zone_mode" ]; then
		printf 'KB_PER_ZONE=%s\n' "$(read_field "$KB/per_zone_mode")"
	fi

	if [ -f "$PROFILE_PATH" ]; then
		printf 'PLATFORM_PROFILE=%s\n' "$(read_field "$PROFILE_PATH")"
	fi

	for field in backlight_timeout battery_limiter boot_animation_sound fan_speed lcd_override usb_charging; do
		path="$PREDATOR/$field"
		if [ -e "$path" ]; then
			var=$(echo "$field" | tr '[:lower:]' '[:upper:]')
			printf '%s=%s\n' "$var" "$(read_field "$path")"
		fi
	done
} > "$tmp"

mv "$tmp" "$STATE_FILE"
