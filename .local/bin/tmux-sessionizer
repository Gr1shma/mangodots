#!/usr/bin/env bash

additional_locations=(
    ~/.config/mango/
    ~/.config/nvim/
    ~/.config/foot/
    ~/.config/eww/
    ~/.local/bin/
)

if [[ $# -eq 1 ]]; then
    selected=$1
else
    base_results=$(fd --type d --max-depth 1 --hidden \
        --exclude '.*' \
        . ~/code/ ~/sem/ ~/ ~/personal ~/projects ~/.local/src/ 2>/dev/null)
    additional_results=$(printf '%s\n' "${additional_locations[@]}")
    selected=$(printf '%s\n%s' "$base_results" "$additional_results" |
        fzf --reverse --no-scrollbar --padding 1,3 --prompt 'Sessions: ')
fi

[[ -z $selected ]] && exit 0

selected_name=$(basename "$selected" | tr ":,. " "____")
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected
    exit 0
fi

if ! tmux has-session -t=$selected_name 2>/dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

tmux switch-client -t $selected_name
